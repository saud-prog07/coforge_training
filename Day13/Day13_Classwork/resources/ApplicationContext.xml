<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:p="http://www.springframework.org/schema/p"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">
	
	<bean id="customer1" class="com.coforge.model.Customer"><!-- Setter Injection -->
		<property name="customerId" value="101"></property>
		<property name="customerName" value="Valan"></property>
		<property name="emails" ><list>
				<value>valan@gmail.com</value>
		<value>valan1@gmail.com</value>
		</list> </property>
		<property name = "deliveryAddress"><list>
				<ref bean = "deliveryaddress1"></ref>
		<ref bean = "deliveryaddress2"></ref>
		</list> </property>
	</bean>
	
	<bean id="customer2" class="com.coforge.model.Customer"><!-- Constructor injection (more better) -->
		<constructor-arg name="customerId" value="102"></constructor-arg>
		<constructor-arg name="customerName" value="Raj"></constructor-arg>
		<constructor-arg name="emails">
		<list>
				<value>raj@gmail.com</value>
		<value>raj1@gmail.com</value>
		</list></constructor-arg>
		<constructor-arg name = "deliveryAddress">
		<list>
				<ref bean = "deliveryaddress1"></ref>
		<ref bean = "deliveryaddress2"></ref>
		</list> </constructor-arg>
	</bean>
	
	<bean id="deliveryaddress1" class = "com.coforge.model.DeliveryAddress">
	<property name="city" value = "Hyderabad"></property>
	<property name="state" value = "Telangana"></property>
	</bean>
	
		<bean id="deliveryaddress2" class = "com.coforge.model.DeliveryAddress">
	<constructor-arg name="city" value = "Banglore"></constructor-arg>
	<constructor-arg name="state" value = "Karnartaka"></constructor-arg>
	</bean>
</beans>